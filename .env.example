# ==========================================================
# Employee Attrition Machine Learning
# Environment Variables
# ==========================================================

# Project Information
PROJECT_NAME=Employee Attrition Machine Learning
PROJECT_VERSION=1.0.0

# Dataset Path
DATA_PATH=data/raw/employee_attrition.csv

# Processed Data
PROCESSED_DATA_PATH=data/processed/

# Saved Models
MODEL_PATH=models/best_model.pkl

# Output Directories
CHARTS_DIR=outputs/charts/
REPORTS_DIR=outputs/reports/
METRICS_DIR=outputs/metrics/

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/logs/project.log

# Random Seed
RANDOM_STATE=42

# Train/Test Split
TEST_SIZE=0.20

# Model Configuration
TARGET_COLUMN=Attrition

# Prediction Output
PREDICTION_OUTPUT=outputs/reports/predictions.csv
